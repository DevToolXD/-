rules_version = '2';

// =============================================================
//  Firestore 보안 규칙 - 마니또 웹앱
// =============================================================
//  ⚠️ 반드시 읽어주세요 (이 스택의 보안 한계)
//  이 앱은 "정적 호스팅 + 이름/비밀번호(자체 인증)" 구조라서
//  Firebase Authentication 을 쓰지 않습니다. 그래서 보안 규칙에서
//  request.auth 로 "누가 요청했는지"를 알 수 없고, 사용자별 권한을
//  규칙 단에서 강제할 수 없습니다.
//
//  그래서 이 앱은 규칙 대신 "암호화"로 핵심 기밀을 지킵니다:
//   1) 전체 마니또 관계(reveal 대상)는 관리자 코드로 AES-GCM 암호화되어
//      meta/mapping 에 저장됩니다. 학생은 코드가 없어 복호화 불가.
//   2) 소원 메시지는 예측 불가능한 128비트 채널 토큰(cid)을 아는
//      사람만 접근할 수 있는 하위 컬렉션에 저장됩니다. channels 컬렉션
//      자체의 열거(list)는 아래 규칙으로 차단됩니다.
//
//  규칙으로 강제되는 것: 컬렉션 열거 차단, 문서 형태(길이/타입) 검증,
//  채널/시크릿 열거 금지, meta·mapping 은 암호문만 저장.
//  규칙으로 강제 불가능한 것(=앱 로직 + 암호화에 의존): "관리자만
//  배정/공개", "본인만 자기 시크릿 수정". 더 강한 보장이 필요하면
//  Firebase Auth + Cloud Functions 로 확장하세요 (README 참고).
// =============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function nonEmptyStr(v, max) {
      return v is string && v.size() > 0 && v.size() <= max;
    }
    function nullableStr(v) {
      return v == null || v is string;
    }

    // ---- 학생 명단: 이름만 저장. 로그인 화면 드롭다운을 위해 조회 허용 ----
    match /students/{id} {
      allow get, list: if true;
      allow create: if nonEmptyStr(request.resource.data.name, 40);
      // 이미 등록된 이름은 수정/삭제 불가 (장난 방지)
      allow update, delete: if false;
    }

    // ---- 시크릿: 비밀번호 해시 + 배정된 채널 토큰 ----
    // get 은 허용하되 list(열거)는 금지하여 토큰 대량 수집을 어렵게 함.
    match /secrets/{id} {
      allow get: if true;
      allow list: if false;
      allow create: if request.resource.data.keys().hasOnly(
                        ['hasPassword','sendChannel','readChannel','salt','pwHash']);
      // 비밀번호 최초 설정 / 관리자 배정으로 채널 갱신에 필요.
      // (자체 인증이라 "본인만" 을 규칙으로 막지는 못함 → 앱 로직 의존)
      allow update: if request.resource.data.keys().hasOnly(
                        ['hasPassword','sendChannel','readChannel','salt','pwHash'])
                    && nullableStr(request.resource.data.sendChannel)
                    && nullableStr(request.resource.data.readChannel);
      allow delete: if false;
    }

    // ---- meta: 관리자 설정(해시) + 배정 매핑(암호문) ----
    // 저장되는 값은 모두 해시/암호문이라 조회돼도 원문이 노출되지 않음.
    match /meta/{docId} {
      allow get: if true;
      allow list: if false;
      allow write: if true; // 값은 암호문/해시. 접근 통제는 암호화가 담당.
    }

    // ---- 채널(소원 메시지함) ----
    // channels 문서/컬렉션 자체는 조회·열거 불가 → cid 를 모르면 도달 불가.
    match /channels/{cid} {
      allow read, write: if false;

      match /messages/{msgId} {
        // cid(비밀 토큰)를 아는 사람만 경로로 접근 가능
        allow get, list: if true;
        allow create: if nonEmptyStr(request.resource.data.text, 500)
                      && request.resource.data.keys().hasOnly(['text','createdAt']);
        allow update, delete: if false;
      }
    }

    // ---- 그 외 모든 경로 거부 (기본값이지만 명시) ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
