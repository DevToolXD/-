rules_version = '2';

// =============================================================
//  Firestore 보안 규칙 - 마니또 웹앱 (학급코드 멀티클래스 구조)
// =============================================================
//  ⚠️ 반드시 읽어주세요 (이 스택의 보안 한계)
//  이 앱은 Firebase Authentication을 쓰지 않는 정적 사이트라서, 보안
//  규칙이 "누가 요청했는지"(request.auth)를 알 수 없습니다. 그래서
//  "본인만 자기 계정 수정", "선생님만 배정" 같은 사용자별 권한은
//  규칙 단에서 강제할 수 없고, 앱 로직(비밀번호/관리자코드 확인)에
//  의존합니다. 아래 규칙이 실제로 강제하는 것은:
//   - 학급코드가 유효한 값(0601~0609, 1889)인 경로만 허용
//   - 컬렉션 열거(list) 차단 (secrets 등) → 무작위 수집 방지
//   - 문서 필드 형태(허용된 키 목록·길이) 검증
//  더 강한 보장이 필요하면 Firebase Auth + Cloud Functions로 확장하세요.
// =============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function nonEmptyStr(v, max) {
      return v is string && v.size() > 0 && v.size() <= max;
    }
    function nullableStr(v, max) {
      return v == null || (v is string && v.size() <= max);
    }
    function validClassCode(code) {
      return code.matches('^(060[1-9]|1889)$');
    }

    match /classes/{code} {
      allow get: if validClassCode(code);
      allow list: if false;
      // adminHash/adminSalt 는 해시값이라 조회돼도 원문이 노출되지 않음
      allow create, update: if validClassCode(code)
        && request.resource.data.keys().hasOnly(['adminSalt','adminHash','createdAt'])
        && nonEmptyStr(request.resource.data.adminHash, 200)
        && nonEmptyStr(request.resource.data.adminSalt, 200);
      allow delete: if false;

      // ---- 학생 명단: 이름만 저장. 선생님이 삭제도 할 수 있음 ----
      match /students/{id} {
        allow get, list: if validClassCode(code);
        allow create: if validClassCode(code) && nonEmptyStr(request.resource.data.name, 40);
        allow update: if false;
        allow delete: if validClassCode(code);
      }

      // ---- 시크릿: 비밀번호 해시 + 소원 + 배정 정보 ----
      match /secrets/{id} {
        allow get: if validClassCode(code);
        allow list: if false;
        allow create: if validClassCode(code) && request.resource.data.keys().hasOnly(
          ['hasPassword','wish','wishSetAt','wishRewriteNote','caringForId','caringForName']);
        allow update: if validClassCode(code)
          && request.resource.data.keys().hasOnly(
               ['hasPassword','wish','wishSetAt','wishRewriteNote','caringForId','caringForName','salt','pwHash'])
          && nullableStr(request.resource.data.get('wish', null), 300)
          && nullableStr(request.resource.data.get('wishRewriteNote', null), 300)
          && nullableStr(request.resource.data.get('caringForId', null), 200)
          && nullableStr(request.resource.data.get('caringForName', null), 40);
        allow delete: if validClassCode(code);
      }

      // ---- meta: 관리자 코드 검증 이력이 필요없는 배정 상태만 ----
      match /meta/{docId} {
        allow get: if validClassCode(code) && docId == 'state';
        allow list: if false;
        allow write: if validClassCode(code) && docId == 'state'
          && request.resource.data.keys().hasOnly(['assignedAt','studentCount','teacherIncluded']);
      }
    }

    // ---- 모드 투표 (뽀로로 모드 / 하츄핑 모드) ----
    match /modeVotes/{id} {
      allow get, list: if true;
      allow create, update: if id in ['pororo', 'hachuping']
        && request.resource.data.keys().hasOnly(['count'])
        && request.resource.data.count is int
        && request.resource.data.count >= 0;
      allow delete: if false;
    }

    // ---- 그 외 모든 경로 거부 ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
